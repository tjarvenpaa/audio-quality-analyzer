# .dockerignore
# Poistetaan turhat tiedostot Docker imagesta

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.venv

# Virtual environments
pip-log.txt
pip-delete-this-directory.txt

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini

# Git
.git/
.gitignore
.gitattributes

# Documentation (optional - poista jos haluat säilyttää)
*.md
!README.md
!QUICKSTART.md

# Testing
tests/
test_*.py
*_test.py
pytest.ini
.pytest_cache/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Output files (don't include in image)
output/
*.xlsx
*.png
*.jpg
*.pdf

# Logs
*.log
logs/

# Temp files
tmp/
temp/
*.tmp

# Large models (download in container)
models/*.pt
models/*.pth
*.onnx

# Development files
*.ipynb
.ipynb_checkpoints/

# Build artifacts
build/
dist/
*.egg-info/

# Coverage reports
htmlcov/
.coverage
.coverage.*

# Docker files (not needed inside image)
Dockerfile*
docker-compose*.yml
.dockerignore

# Input audio (mount as volume)
input_folder/*
!input_folder/.gitkeep
